{
  "version": 2,
  "rewrites": [
    { "source": "/api/health", "destination": "/api/health.ts" },
    { "source": "/api/send-notification", "destination": "/api/send-notification.ts" },
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/sw.js", "destination": "/sw.js" },
    { "source": "/OneSignalSDKWorker.js", "destination": "/OneSignalSDKWorker.js" },
    { "source": "/icon.svg", "destination": "/icon.svg" },
    { "source": "/manifest.json", "destination": "/manifest.json" },
    { "source": "/logo.png", "destination": "/logo.png" },
    { "source": "/((?!api/|assets/|.*\\..*).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/OneSignalSDKWorker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Content-Type",
          "value": "application/javascript"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline' https://cdn.onesignal.com https://api.onesignal.com https://onesignal.com; style-src 'self' 'unsafe-inline' https://cdn.onesignal.com https://onesignal.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.onesignal.com https://api.onesignal.com; img-src 'self' data: https:; font-src 'self' data:; worker-src 'self' https://cdn.onesignal.com https://onesignal.com blob:;"
        }
      ]
    }
  ]
}
