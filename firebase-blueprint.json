{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application, typically a shop owner.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "shop_id": { "type": "string", "description": "ID of the shop owned by this user (for shop owners)" },
        "role": { "type": "string", "enum": ["admin", "user", "customer"] }
      },
      "required": ["uid", "email"]
    },
    "Shop": {
      "title": "Shop",
      "description": "A racquet stringing shop.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "slug": { "type": "string", "description": "Custom URL handle for the shop" },
        "owner_id": { "type": "string", "description": "UID of the owner" },
        "qr_code": { "type": "string" }
      },
      "required": ["id", "name", "owner_id"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A customer of a shop.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shop_id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "uid": { "type": "string", "description": "Firebase Auth UID of the linked user" },
        "is_lead": { "type": "boolean", "description": "True if the customer was created from a public inquiry without registration" }
      },
      "required": ["id", "shop_id", "name"]
    },
    "Racquet": {
      "title": "Racquet",
      "description": "A tennis racquet owned by a customer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customer_id": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "serial_number": { "type": "string" },
        "head_size": { "type": "number" },
        "string_pattern_mains": { "type": "number" },
        "string_pattern_crosses": { "type": "number" },
        "mains_skip": { "type": "string", "description": "Skipped holes for mains" },
        "mains_tie_off": { "type": "string", "description": "Tie-off location for mains" },
        "crosses_start": { "type": "string", "description": "Starting point for crosses" },
        "crosses_tie_off": { "type": "string", "description": "Tie-off location for crosses" },
        "one_piece_length": { "type": "string", "description": "Length for one-piece stringing (ft)" },
        "two_piece_length": { "type": "string", "description": "Length for two-piece stringing (ft)" },
        "stringing_instructions": { "type": "string", "description": "General stringing instructions" },
        "current_string_main": { "type": "string" },
        "current_string_cross": { "type": "string" },
        "current_tension_main": { "type": "number" },
        "current_tension_cross": { "type": "number" },
        "qr_code": { "type": "string" }
      },
      "required": ["id", "customer_id", "brand", "model"]
    },
    "Job": {
      "title": "Job",
      "description": "A stringing job for a racquet.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "racquet_id": { "type": "string" },
        "shop_id": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed"] },
        "string_main": { "type": "string" },
        "string_cross": { "type": "string" },
        "tension_main": { "type": "number" },
        "tension_cross": { "type": "number" },
        "price": { "type": "number" },
        "payment_status": { "type": "string", "enum": ["paid", "unpaid"] },
        "service_type": { "type": "string", "enum": ["string_full_bed", "string_hybrid", "string_grip", "string_dampener", "string_grip_dampener", "custom"] },
        "custom_service_category": { "type": "string", "enum": ["string", "grip", "dampener"] },
        "additional_service_request": { "type": "string" },
        "notes": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "racquet_id", "shop_id", "status"]
    },
    "InventoryItem": {
      "title": "InventoryItem",
      "description": "An item in the shop's inventory.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shop_id": { "type": "string" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "type": { "type": "string", "enum": ["string", "grip", "dampener", "other"] },
        "packaging": { "type": "string", "enum": ["reel", "set"], "description": "Reel (200m/660ft) or Set (12m/40ft)" },
        "total_length": { "type": "number", "description": "Total length of a single unit (m or ft)" },
        "remaining_length": { "type": "number", "description": "Remaining length of the CURRENT open unit" },
        "quantity": { "type": "number", "description": "Number of unopened units in stock" },
        "low_stock_threshold": { "type": "number", "description": "Alert when quantity falls below this" },
        "price": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "shop_id", "name", "type", "packaging", "quantity"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a customer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customer_email": { "type": "string", "format": "email" },
        "shop_id": { "type": "string" },
        "job_id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "customer_email", "title", "message", "read", "created_at"]
    },
    "Message": {
      "title": "Message",
      "description": "A message between a customer and a shop.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shop_id": { "type": "string" },
        "customer_id": { "type": "string", "description": "ID from the customers collection" },
        "sender_id": { "type": "string", "description": "UID of the sender" },
        "sender_name": { "type": "string" },
        "sender_role": { "type": "string", "enum": ["stringer", "customer", "anonymous"] },
        "content": { "type": "string" },
        "read": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" },
        "customer_email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "title": { "type": "string" },
        "service_requested": { "type": "string" }
      },
      "required": ["id", "shop_id", "content", "sender_role", "created_at"]
    },
    "RacquetSpecCache": {
      "title": "RacquetSpecCache",
      "description": "Cached racquet specifications to reduce API calls.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "brand_model slug" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "specs": { "type": "object", "description": "The full specs object from Gemini" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "brand", "model", "specs", "created_at"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/shops/{shopId}": { "schema": "Shop", "description": "Shop details" },
    "/customers/{customerId}": { "schema": "Customer", "description": "Customer records" },
    "/racquets/{racquetId}": { "schema": "Racquet", "description": "Racquet records" },
    "/jobs/{jobId}": { "schema": "Job", "description": "Stringing jobs" },
    "/inventory/{itemId}": { "schema": "InventoryItem", "description": "Inventory items" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications" },
    "/messages/{messageId}": { "schema": "Message", "description": "Shop messages" },
    "/racquet_specs_cache/{cacheId}": { "schema": "RacquetSpecCache", "description": "Cached racquet specs" }
  }
}
